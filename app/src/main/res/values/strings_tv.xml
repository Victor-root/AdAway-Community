<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- TV home status header -->
    <string name="tv_status_enabled">Ad-blocking: enabled</string>
    <string name="tv_status_disabled">Ad-blocking: disabled</string>
    <!-- TV home buttons. Block-list-centric wording is intentional: it stays accurate
         whether ad-blocking runs in VPN mode (in-memory DNS filter) or in root mode
         (system /etc/hosts file). The toggle and DNS-monitor buttons reuse the
         existing button_enable_hosts / button_disable_hosts / shortcut_dns_requests
         strings, which are already neutral. -->
    <string name="tv_button_update_block_lists">Update block lists</string>
    <string name="tv_button_sync">Sync block lists</string>
    <string name="tv_button_block_list_sources">Block list sources</string>
    <!-- TV DNS log entry dialog -->
    <string name="tv_dialog_add_to_allowed">Add to allowed</string>
    <string name="tv_dialog_add_to_blocked">Add to blocked</string>
    <string name="tv_dialog_remove_from_allowed">Remove from allowed</string>
    <string name="tv_dialog_remove_from_blocked">Remove from blocked</string>
    <string name="tv_dialog_copy_hostname">Copy hostname</string>
    <!-- TV log row content description -->
    <string name="tv_log_entry_status_description">Domain status</string>
    <!-- TV Always-on VPN setup hint (one-time, shown after the first VPN activation) -->
    <string name="tv_always_on_hint_title">Make AdAway VPN stick</string>
    <string name="tv_always_on_hint_message">AdAway already keeps the VPN running across reboots and low-memory kills. For the strongest guarantee, also enable "Always-on VPN" for AdAway in the Android system settings.</string>
    <string name="tv_always_on_hint_open_settings">Open VPN settings</string>
    <string name="tv_always_on_hint_later">Got it</string>
    <!-- Fallback when the Android TV launcher hides the VPN settings activity -->
    <string name="tv_always_on_fallback_title">VPN settings hidden on this device</string>
    <string name="tv_always_on_fallback_message">Your Android TV launcher does not expose the VPN settings screen. Always-on VPN can still be enabled over ADB:\n\nadb shell settings put global always_on_vpn_app %1$s\n\nOptional (block traffic when VPN is off):\nadb shell settings put global always_on_vpn_lockdown 1\n\nThe change persists across reboots and is equivalent to toggling the Always-on switch in the hidden UI.</string>
</resources>
