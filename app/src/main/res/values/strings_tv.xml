<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- TV home status header -->
    <string name="tv_status_enabled">Ad-blocking: enabled</string>
    <string name="tv_status_disabled">Ad-blocking: disabled</string>
    <!-- TV home buttons. Block-list-centric wording is intentional: it stays accurate
         whether ad-blocking runs in VPN mode (in-memory DNS filter) or in root mode
         (system /etc/hosts file). The toggle and DNS-monitor buttons reuse the
         existing button_enable_hosts / button_disable_hosts / shortcut_dns_requests
         strings, which are already neutral. -->
    <string name="tv_button_update_block_lists">Update block lists</string>
    <string name="tv_button_sync">Sync block lists</string>
    <string name="tv_button_block_list_sources">Block list sources</string>
    <!-- TV DNS log entry dialog -->
    <string name="tv_dialog_add_to_allowed">Add to allowed</string>
    <string name="tv_dialog_add_to_blocked">Add to blocked</string>
    <string name="tv_dialog_remove_from_allowed">Remove from allowed</string>
    <string name="tv_dialog_remove_from_blocked">Remove from blocked</string>
    <string name="tv_dialog_copy_hostname">Copy hostname</string>
    <!-- TV log row content description -->
    <string name="tv_log_entry_status_description">Domain status</string>
    <!-- TV "VPN persistence" button (always accessible in row 3) and the
         passive on-screen indicator that confirms the Android system has
         AdAway set as the Always-on VPN. -->
    <string name="tv_button_vpn_persistence">VPN persistence</string>
    <string name="tv_persistence_indicator_active">Always-on VPN active</string>
    <!-- Dialog opened either on first VPN activation OR via the VPN
         persistence button. Status line + explanation + ADB commands. -->
    <string name="tv_always_on_hint_title">VPN persistence</string>
    <string name="tv_always_on_hint_message">AdAway\'s built-in persistence (foreground service, sticky restart, periodic heartbeat, auto-start on boot) already keeps the VPN running through reboots and low-memory kills — you normally don\'t need anything else.\n\nOnly if you ever notice the VPN stopping unexpectedly on this device, you can additionally pin AdAway as the Android system Always-on VPN for the strongest possible guarantee.</string>
    <string name="tv_persistence_status_enabled">Always-on VPN is enabled for AdAway. ✓</string>
    <string name="tv_persistence_status_disabled">Always-on VPN is not configured — AdAway\'s built-in persistence is in charge.</string>
    <string name="tv_persistence_adb_commands">If you want to enable Always-on VPN and the system VPN screen is hidden by your TV launcher, ADB works around that:\n\n• Enable always-on for AdAway:\n  adb shell settings put global always_on_vpn_app %1$s\n\n• Disable always-on:\n  adb shell settings delete global always_on_vpn_app</string>
    <string name="tv_always_on_hint_open_settings">Open VPN settings</string>
    <string name="tv_always_on_hint_later">Got it</string>
    <!-- Toast shown when the Android TV launcher hides the VPN settings activity
         and the Intent cannot be resolved. The ADB commands stay visible in the
         dialog so the user always has a fallback. -->
    <string name="tv_persistence_intent_failed">VPN settings hidden on this Android TV — use the ADB commands shown.</string>
</resources>
