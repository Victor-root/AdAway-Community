<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!--
        Header band split in two rows so the action buttons never compete with
        the title for horizontal space. With the title alone on row 1 and the
        three buttons on row 2, even very long French translations like
        "Démarrer l'enregistrement (VPN non actif)" stay on a single line.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorPrimary"
        android:paddingHorizontal="24dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- Row 1: title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_record_24dp"
                android:contentDescription="@string/shortcut_dns_requests"
                app:tint="?attr/colorOnPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/shortcut_dns_requests"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>

        <!-- Row 2: action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_refresh"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_refresh"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnPrimary"
                android:focusable="true"
                android:layout_marginEnd="8dp"
                android:nextFocusRight="@id/btn_toggle_recording"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_sync_24dp"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="18dp"
                app:iconTint="?attr/colorOnPrimary"
                app:strokeColor="?attr/colorOnPrimary"
                app:rippleColor="?attr/colorOnPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_toggle_recording"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_start_recording_button"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnPrimary"
                android:focusable="true"
                android:layout_marginEnd="8dp"
                android:nextFocusLeft="@id/btn_refresh"
                android:nextFocusRight="@id/btn_clear"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_record_24dp"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="18dp"
                app:iconTint="?attr/colorOnPrimary"
                app:strokeColor="?attr/colorOnPrimary"
                app:rippleColor="?attr/colorOnPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tcpdump_menu_clear"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnPrimary"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_toggle_recording"
                app:cornerRadius="20dp"
                app:icon="@drawable/baseline_clear_all_24"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="18dp"
                app:iconTint="?attr/colorOnPrimary"
                app:strokeColor="?attr/colorOnPrimary"
                app:rippleColor="?attr/colorOnPrimary" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/log_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/empty_text_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="48dp"
            android:text="@string/log_description_start_recording"
            android:textAppearance="?attr/textAppearanceBody1"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
