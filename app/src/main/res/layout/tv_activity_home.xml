<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Top bar: brand band with logo + app name -->
    <LinearLayout
        android:id="@+id/tv_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorPrimary"
        android:paddingHorizontal="32dp"
        android:paddingVertical="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logo"
            android:contentDescription="@string/app_name"
            app:tint="?attr/colorOnPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:textColor="?attr/colorOnPrimary" />
    </LinearLayout>

    <!-- Status hero: colored circle + check/block icon + status text + state detail -->
    <FrameLayout
        android:id="@+id/tv_status_badge_container"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tv_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/tv_status_badge"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tv_status_circle"
            android:backgroundTint="@color/cardBackground" />

        <ImageView
            android:id="@+id/tv_status_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/baseline_block_24"
            android:contentDescription="@string/tv_log_entry_status_description"
            app:tint="@android:color/white" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textAppearance="?attr/textAppearanceHeadline4"
        app:layout_constraintTop_toBottomOf="@id/tv_status_badge_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Ad-blocking: disabled" />

    <TextView
        android:id="@+id/tv_state_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="?attr/textAppearanceBody1"
        app:layout_constraintTop_toBottomOf="@id/tv_status_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Status: idle" />

    <!-- Primary toggle button (large, filled) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:paddingHorizontal="40dp"
        android:paddingVertical="16dp"
        android:text="@string/button_enable_hosts"
        android:textSize="18sp"
        android:focusable="true"
        android:focusedByDefault="true"
        android:nextFocusDown="@id/btn_update"
        app:cornerRadius="28dp"
        app:icon="@drawable/ic_tv_power_24"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconSize="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_state_detail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Secondary actions: 4 outlined buttons in a row -->
    <LinearLayout
        android:id="@+id/tv_actions_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btn_toggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_button_update_block_lists"
            android:focusable="true"
            android:layout_marginEnd="12dp"
            android:nextFocusRight="@id/btn_sync"
            android:nextFocusUp="@id/btn_toggle"
            android:nextFocusDown="@id/btn_dns_monitor"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_get_app_24dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sync"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_button_sync"
            android:focusable="true"
            android:nextFocusLeft="@id/btn_update"
            android:nextFocusUp="@id/btn_toggle"
            android:nextFocusDown="@id/btn_dns_monitor"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_sync_24dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />
    </LinearLayout>

    <!-- Tertiary actions: DNS monitor + Sources -->
    <LinearLayout
        android:id="@+id/tv_actions_row2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_actions_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dns_monitor"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shortcut_dns_requests"
            android:focusable="true"
            android:layout_marginEnd="12dp"
            android:nextFocusUp="@id/btn_update"
            android:nextFocusRight="@id/btn_sources"
            app:icon="@drawable/ic_record_24dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sources"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_button_block_list_sources"
            android:focusable="true"
            android:nextFocusUp="@id/btn_sync"
            android:nextFocusLeft="@id/btn_dns_monitor"
            app:icon="@drawable/ic_collections_bookmark_24dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />
    </LinearLayout>

    <!-- Progress indicator (shown when adblock model is pending) -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
