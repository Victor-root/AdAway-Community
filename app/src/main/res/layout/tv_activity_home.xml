<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Top brand band: logo + app name -->
    <LinearLayout
        android:id="@+id/tv_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorPrimary"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/logo"
            android:contentDescription="@string/app_name"
            app:tint="?attr/colorOnPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:textColor="?attr/colorOnPrimary" />
    </LinearLayout>

    <!-- Horizontal status row: badge (left) + status text (right) -->
    <LinearLayout
        android:id="@+id/tv_status_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">

            <View
                android:id="@+id/tv_status_badge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/tv_status_circle"
                android:backgroundTint="@color/cardBackground" />

            <ImageView
                android:id="@+id/tv_status_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_block_24"
                android:contentDescription="@string/tv_log_entry_status_description"
                app:tint="@android:color/white" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tv_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadline6"
                tools:text="Ad-blocking: disabled" />

            <TextView
                android:id="@+id/tv_state_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.7"
                tools:text="Status: idle" />
        </LinearLayout>
    </LinearLayout>

    <!-- Primary toggle button (compact) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:text="@string/button_enable_hosts"
        android:textSize="14sp"
        android:singleLine="true"
        android:focusable="true"
        android:focusedByDefault="true"
        android:nextFocusDown="@id/btn_update"
        app:cornerRadius="24dp"
        app:icon="@drawable/ic_tv_power_24"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_status_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Secondary actions: 4 buttons in a single row -->
    <LinearLayout
        android:id="@+id/tv_actions_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btn_toggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_button_update_block_lists"
            android:textSize="12sp"
            android:singleLine="true"
            android:paddingHorizontal="14dp"
            android:focusable="true"
            android:layout_marginEnd="10dp"
            android:nextFocusLeft="@id/btn_toggle"
            android:nextFocusRight="@id/btn_sync"
            android:nextFocusUp="@id/btn_toggle"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_get_app_24dp"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sync"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_button_sync"
            android:textSize="12sp"
            android:singleLine="true"
            android:paddingHorizontal="14dp"
            android:focusable="true"
            android:layout_marginEnd="10dp"
            android:nextFocusLeft="@id/btn_update"
            android:nextFocusRight="@id/btn_dns_monitor"
            android:nextFocusUp="@id/btn_toggle"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_sync_24dp"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dns_monitor"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shortcut_dns_requests"
            android:textSize="12sp"
            android:singleLine="true"
            android:paddingHorizontal="14dp"
            android:focusable="true"
            android:layout_marginEnd="10dp"
            android:nextFocusLeft="@id/btn_sync"
            android:nextFocusRight="@id/btn_sources"
            android:nextFocusUp="@id/btn_toggle"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_record_24dp"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sources"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_button_block_list_sources"
            android:textSize="12sp"
            android:singleLine="true"
            android:paddingHorizontal="14dp"
            android:focusable="true"
            android:nextFocusLeft="@id/btn_dns_monitor"
            android:nextFocusUp="@id/btn_toggle"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_collections_bookmark_24dp"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="18dp" />
    </LinearLayout>

    <!-- Progress indicator -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
